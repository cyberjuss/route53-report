#!/usr/bin/env python3
"""
Route 53 External-Facing IPv4 Inventory
=======================================
Pulls every A record from Route 53, performs a live DNS lookup
(nslookup-style) on each record name, and reports the resulting
external-facing (public) IPv4 addresses as a CSV column and a PDF table.

Runs both locally (python3 external_ips.py) and as an AWS Lambda
(handler = external_ips.lambda_handler).
"""

import csv
import ipaddress
import os
import socket
from concurrent.futures import ThreadPoolExecutor
from datetime import date

import boto3
from reportlab.lib import colors
from reportlab.lib.pagesizes import letter
from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
from reportlab.lib.units import inch
from reportlab.platypus import SimpleDocTemplate, Table, TableStyle, Paragraph, Spacer


# ---------------------------------------------------------------- Config

# Inventory names ending in any of these suffixes (both are public-facing).
ALLOWED_SUFFIXES = (".gov", ".com")

# Suffixes that are private / non-routable and never external-facing.
EXCLUDED_SUFFIXES = (".internal",)

# Keep only globally-routable (public) IPs. Drops anything in the
# private RFC 1918 ranges (10.x, 172.16-31.x, 192.168.x), loopback, etc.
PUBLIC_ONLY = True

# Per-lookup DNS timeout in seconds, so a slow name can't hang the run.
socket.setdefaulttimeout(3)

CSV_FIELDS = ["record_name", "ipv4"]


# ---------------------------------------------------------------- Route 53

def fetch_a_record_names():
    """Return a de-duplicated list of A-record names from Route 53."""
    r53 = boto3.client("route53")

    seen = set()
    names = []

    zone_pages = r53.get_paginator("list_hosted_zones").paginate()

    for zone_page in zone_pages:
        for zone in zone_page["HostedZones"]:
            zone_id = zone["Id"].split("/")[-1]

            rec_pages = r53.get_paginator(
                "list_resource_record_sets"
            ).paginate(HostedZoneId=zone_id)

            for rec_page in rec_pages:
                for rec in rec_page["ResourceRecordSets"]:

                    # Only A records.
                    if rec["Type"] != "A":
                        continue

                    name = rec["Name"].rstrip(".").replace("\\052", "*")
                    lower = name.lower()

                    if not lower.endswith(ALLOWED_SUFFIXES):
                        continue

                    if lower.endswith(EXCLUDED_SUFFIXES):
                        continue

                    # Wildcards (*.example.gov) can't be resolved directly.
                    if "*" in name:
                        continue

                    if name not in seen:
                        seen.add(name)
                        names.append(name)

    return names


# ---------------------------------------------------------------- nslookup

def resolve_ipv4(name):
    """Forward DNS lookup. Returns a sorted list of public IPv4 strings."""
    try:
        _, _, ips = socket.gethostbyname_ex(name)
    except (socket.gaierror, socket.timeout, OSError):
        return []

    out = []
    for ip in sorted(set(ips)):
        if PUBLIC_ONLY:
            try:
                if not ipaddress.ip_address(ip).is_global:
                    continue
            except ValueError:
                continue
        out.append(ip)

    return out


def build_rows(names):
    """Resolve every name (in parallel) into flat {record_name, ipv4} rows."""
    rows = []

    with ThreadPoolExecutor(max_workers=20) as pool:
        results = list(pool.map(lambda n: (n, resolve_ipv4(n)), names))

    for name, ips in results:
        for ip in ips:
            rows.append({"record_name": name, "ipv4": ip})

    return rows


# ---------------------------------------------------------------- CSV

def write_csv(rows, path):
    with open(path, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=CSV_FIELDS)
        writer.writeheader()
        writer.writerows(rows)

    print(f"[+] CSV written: {path} ({len(rows)} IPs)")


# ---------------------------------------------------------------- PDF

def build_pdf(rows, out_path):
    doc = SimpleDocTemplate(
        out_path,
        pagesize=letter,
        leftMargin=0.75 * inch,
        rightMargin=0.75 * inch,
        topMargin=0.75 * inch,
        bottomMargin=0.75 * inch,
        title="Route 53 External-Facing IPv4 Addresses",
    )

    styles = getSampleStyleSheet()

    title_style = ParagraphStyle(
        "title", parent=styles["Title"], textColor=colors.black)
    subtitle_style = ParagraphStyle(
        "subtitle", parent=styles["Normal"], alignment=1,
        fontSize=11, textColor=colors.black)
    cell = ParagraphStyle(
        "cell", parent=styles["Normal"], fontSize=9,
        leading=12, textColor=colors.black)

    table_style = TableStyle([
        ("FONTNAME", (0, 0), (-1, 0), "Helvetica-Bold"),
        ("FONTSIZE", (0, 0), (-1, 0), 10.5),
        ("LINEBELOW", (0, 0), (-1, 0), 1.2, colors.black),
        ("FONTNAME", (0, 1), (-1, -1), "Helvetica"),
        ("FONTSIZE", (0, 1), (-1, -1), 9),
        ("TEXTCOLOR", (0, 0), (-1, -1), colors.black),
        ("GRID", (0, 0), (-1, -1), 0.6, colors.black),
        ("VALIGN", (0, 0), (-1, -1), "TOP"),
        ("LEFTPADDING", (0, 0), (-1, -1), 5),
        ("RIGHTPADDING", (0, 0), (-1, -1), 5),
        ("TOPPADDING", (0, 0), (-1, -1), 4),
        ("BOTTOMPADDING", (0, 0), (-1, -1), 4),
    ])

    story = []
    story.append(Paragraph(date.today().strftime("%B %d, %Y"), title_style))
    story.append(Paragraph(
        "Route 53 External-Facing IPv4 Addresses", subtitle_style))
    story.append(Spacer(1, 16))

    data = [["Record", "IPv4"]]
    for r in sorted(rows, key=lambda x: (x["record_name"], x["ipv4"])):
        data.append([Paragraph(r["record_name"], cell), r["ipv4"]])

    table = Table(
        data,
        colWidths=[4.6 * inch, 2.4 * inch],
        repeatRows=1,
        hAlign="CENTER",
    )
    table.setStyle(table_style)

    story.append(table)
    doc.build(story)

    print(f"[+] PDF written: {out_path}")


# ---------------------------------------------------------------- S3

def upload_to_s3(file_path, bucket, key):
    s3 = boto3.client("s3")
    s3.upload_file(file_path, bucket, key)
    print(f"[+] Uploaded to s3://{bucket}/{key}")


# ---------------------------------------------------------------- Workflow

def run(output_dir, s3_bucket=None, prefix="reports", upload=True, stamp=None):
    print("[*] Starting Route 53 external-facing IPv4 lookup")

    if stamp is None:
        stamp = date.today().strftime("%Y-%m-%d")

    os.makedirs(output_dir, exist_ok=True)

    names = fetch_a_record_names()

    if not names:
        print("[!] No A records found")
        return {"status": "no_a_records_found"}

    rows = build_rows(names)

    base = f"route53_external_ips_{stamp}"
    pdf_path = os.path.join(output_dir, f"{base}.pdf")
    csv_path = os.path.join(output_dir, f"{base}.csv")

    build_pdf(rows, pdf_path)
    write_csv(rows, csv_path)

    pdf_key = f"{prefix}/_external-ips/{base}.pdf"
    csv_key = f"{prefix}/_external-ips/{base}.csv"

    if upload and s3_bucket:
        upload_to_s3(file_path=pdf_path, bucket=s3_bucket, key=pdf_key)
        upload_to_s3(file_path=csv_path, bucket=s3_bucket, key=csv_key)

    print(
        f"[*] Resolved {len(names)} A-record names "
        f"-> {len(rows)} public IPs"
    )
    print("[+] Completed successfully")

    return {
        "status": "success",
        "a_records": len(names),
        "public_ips": len(rows),
        "s3_bucket": s3_bucket,
        "pdf": pdf_path,
        "csv": csv_path,
    }


# ---------------------------------------------------------------- Lambda

def lambda_handler(event, context):
    s3_bucket = os.environ["S3_BUCKET"]
    prefix = os.environ.get("S3_PREFIX", "reports")

    return run(
        output_dir="/tmp",
        s3_bucket=s3_bucket,
        prefix=prefix,
        upload=True,
    )


# ---------------------------------------------------------------- Local

if __name__ == "__main__":
    # Replace the placeholder, or set S3_BUCKET in your environment.
    bucket = os.environ.get("S3_BUCKET", "REPLACE_WITH_YOUR_BUCKET_NAME")
    prefix = os.environ.get("S3_PREFIX", "reports")

    result = run(
        output_dir="aws-route53-external-ips",
        s3_bucket=bucket,
        prefix=prefix,
        upload=bool(bucket),
    )

    print(result)
